{
  "name": "@revisium/revo-agent-runtime",
  "version": "0.0.0",
  "description": "Portable, invocation-scoped agent execution runtime for Revo.",
  "homepage": "https://github.com/revisium/revo-agent-runtime#readme",
  "bugs": {
    "url": "https://github.com/revisium/revo-agent-runtime/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revisium/revo-agent-runtime.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist coverage",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --type-aware --type-check --deny-warnings --report-unused-disable-directives .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:unit": "vitest run test/unit",
    "test:contract": "vitest run test/contract",
    "test:package": "vitest run test/package",
    "test:architecture": "node --import tsx scripts/verify-architecture.ts",
    "test": "pnpm run test:unit && pnpm run test:contract && pnpm run test:package",
    "test:cov": "vitest run --coverage",
    "verify:architecture": "pnpm run test:architecture",
    "verify:package": "pnpm run build && publint && node --import tsx scripts/verify-package.ts",
    "verify": "pnpm run format:check && pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run test:cov && pnpm run verify:architecture && pnpm run verify:package",
    "sonar:local": "bash scripts/sonar-local.sh",
    "sonar:issues:local": "bash scripts/sonar-issues-local.sh",
    "ci:local:sonar": "bash scripts/ci-local-sonar.sh",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "canonicalize": "3.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.9",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "publint": "0.3.21",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.11.1 <25"
  },
  "packageManager": "pnpm@11.13.0"
}
